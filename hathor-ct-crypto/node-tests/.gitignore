# Generated by `napi build`. index.js is a platform-dispatch loader and
# *.node is platform-specific, so both are ignored. index.d.ts is tracked
# so that changes to the napi binding surface show up as a clean diff in
# code review — regenerate via `npm run build:debug` when the Rust
# signatures change.
index.js
*.node
